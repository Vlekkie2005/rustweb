  "query": "UPDATE friend\n               SET status = 'accepted'::friend_status, updated_at = NOW()\n               WHERE user_one_id = $1\n                 AND user_two_id = $2\n                 AND status = 'pending'::friend_status\n               RETURNING\n                   user_one_id,\n                   user_two_id,\n                   requested_by,\n                   status AS \"status!: FriendStatus\",\n                   created_at,\n                   updated_at",
