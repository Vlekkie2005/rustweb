{
  "db_name": "PostgreSQL",
  "query": "SELECT c.id, c.created_at, c.name, c.type AS \"type: ChannelType\", u.username AS channel_name\n                FROM channel c\n                JOIN participant p ON p.channel_id = c.id AND p.user_id != $2\n                JOIN users u ON u.id = p.user_id\n                WHERE c.id = $1\n                AND c.type = 'dm'::channel_type\n                LIMIT 1",
